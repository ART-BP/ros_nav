<launch>
  <!-- Arguments -->
  <arg name="cmd_vel_topic" default="/cmd_vel" />
  <arg name="odom_topic" default="odom" />
  <arg name="dog_name" default="big_dog" />  
  

  <!-- move_base -->
  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <param name="base_local_planner" value="teb_local_planner/TebLocalPlannerROS" />
    <param name="base_global_planner" value="global_planner/GlobalPlanner" />
    <rosparam file="$(find omni_navigation)/param/$(arg dog_name)/teb/costmap_common_params_omni.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(find omni_navigation)/param/$(arg dog_name)/teb/costmap_common_params_omni.yaml" command="load" ns="local_costmap" />
    <rosparam file="$(find omni_navigation)/param/$(arg dog_name)/teb/local_costmap_params.yaml" command="load"  />
    <rosparam file="$(find omni_navigation)/param/$(arg dog_name)/teb/global_costmap_params.yaml" command="load" />
    <rosparam file="$(find omni_navigation)/param/$(arg dog_name)/teb/move_base_params.yaml" command="load" />
    <rosparam file="$(find omni_navigation)/param/$(arg dog_name)/teb/teb_local_planner_params.yaml" command="load" />
    <rosparam file="$(find omni_navigation)/param/$(arg dog_name)/teb/global_planner_params_gp.yaml" command="load" />
    <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
    <remap from="odom" to="$(arg odom_topic)"/>
  </node>
</launch>
